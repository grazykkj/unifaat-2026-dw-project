{
    "openapi": "3.0.0",
    "info": {
        "title": "Course API",
        "version": "1.0.0",
        "description": "API de cursos - CRUD completo"
    },
    "paths": {
        "/courses": {
            "get": {
                "summary": "Listar cursos",
                "description": "Retorna uma lista paginada de cursos com os usuarios vinculados",
                "parameters": [
                    {
                        "name": "page",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "default": 1
                        },
                        "description": "Pagina desejada"
                    },
                    {
                        "name": "limit",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "default": 10,
                            "maximum": 20
                        },
                        "description": "Quantidade maxima de itens por pagina"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Lista de cursos",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/CourseListResponse"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Erro interno do servidor"
                    }
                }
            },
            "post": {
                "summary": "Criar curso",
                "description": "Cria um novo curso com nome e professor",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/CourseInput"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Curso criado",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Course"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Nome ou professor nao informado"
                    },
                    "500": {
                        "description": "Erro interno do servidor"
                    }
                }
            }
        },
        "/courses/{id}": {
            "get": {
                "summary": "Obter curso",
                "description": "Retorna um curso pelo ID com os usuarios vinculados",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Curso encontrado",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/CourseWithUsers"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Curso nao encontrado"
                    },
                    "500": {
                        "description": "Erro interno do servidor"
                    }
                }
            },
            "put": {
                "summary": "Atualizar curso",
                "description": "Atualiza nome e professor de um curso existente",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/CourseInput"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Curso atualizado",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Course"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Nome e professor sao obrigatorios"
                    },
                    "404": {
                        "description": "Curso nao encontrado"
                    },
                    "500": {
                        "description": "Erro interno do servidor"
                    }
                }
            },
            "delete": {
                "summary": "Deletar curso",
                "description": "Remove um curso pelo ID",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "204": {
                        "description": "Curso deletado"
                    },
                    "404": {
                        "description": "Curso nao encontrado"
                    },
                    "500": {
                        "description": "Erro interno do servidor"
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "CourseInput": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "professor": {
                        "type": "string"
                    }
                },
                "required": [
                    "name",
                    "professor"
                ]
            },
            "Course": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer"
                    },
                    "name": {
                        "type": "string"
                    },
                    "professor": {
                        "type": "string"
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time"
                    }
                }
            },
            "CourseWithUsers": {
                "allOf": [
                    {
                        "$ref": "#/components/schemas/Course"
                    },
                    {
                        "type": "object",
                        "properties": {
                            "users": {
                                "type": "array",
                                "items": {
                                    "type": "object"
                                }
                            }
                        }
                    }
                ]
            },
            "CourseListResponse": {
                "type": "object",
                "properties": {
                    "page": {
                        "type": "integer"
                    },
                    "limit": {
                        "type": "integer"
                    },
                    "total": {
                        "type": "integer"
                    },
                    "next": {
                        "type": [
                            "integer",
                            "null"
                        ]
                    },
                    "data": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/CourseWithUsers"
                        }
                    }
                }
            }
        }
    }
}
